generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Lead {
  id        Int      @id @default(autoincrement())
  nome      String
  telefone  String
  email     String?
  origem    String   @default("popup")
  criadoEm  DateTime @default(now())
  lido      Boolean  @default(false)
}
